# Legal AI Platform — Environment Configuration
# Copy this file to .env and fill in your values

# Database (defaults to SQLite if not set)
# DATABASE_URL=postgresql://user:password@localhost:5432/legal_ai
DATABASE_URL=sqlite:///./legal_ai.db

# ChromaDB vector store path (defaults to backend/chroma_db)
# CHROMA_DB_PATH=./chroma_db

# Tesseract OCR path (only needed for scanned PDFs)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: usually auto-detected on PATH
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
